generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id           String   @id @default(uuid())
  physicalType String
  createdAt    DateTime @default(now())
}

model User {
  id             String   @id @default(uuid())
  cpf            String   @unique
  nome           String   // Necessário para o FHIR Parser!
  passwordHash   String
  role           String
  practitionerId String
  createdAt      DateTime @default(now())
}

model Encounter {
  id         String   @id @default(uuid())
  locationId String
  status     String
  date       DateTime @default(now())
}