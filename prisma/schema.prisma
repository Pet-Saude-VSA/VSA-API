// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id           String   @id @default(uuid())
  physicalType String
  createdAt    DateTime @default(now())
}